// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String         @id @default(uuid())
  email     String         @unique
  password  String
  name      String?
  createdAt DateTime       @default(now())
  conversations Conversation[]
}

model Conversation {
  id          String       @id @default(uuid())
  title       String
  rawText     String
  summary     String?
  insights    String?
  tags        String?
  aiSource    String       @default("other")
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
